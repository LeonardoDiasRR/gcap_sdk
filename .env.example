# ========================================
# Configurações do Backend GCAP (Supabase)
# ========================================

# URL base do backend GCAP
GCAP_BACKEND_URL_BASE=https://your-supabase-project.supabase.co

# ID da unidade (substituir pelo seu ID)
GCAP_BACKEND_UNIDADE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Chave de API para autenticação
GCAP_BACKEND_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Credenciais de usuário para login
GCAP_BACKEND_USER=seu.email@example.com
GCAP_BACKEND_PASSWORD=sua_senha_segura

# ========================================
# Configurações do Storage S3 (Supabase)
# ========================================

# URL base do S3
S3_URL=https://your-supabase-project.storage.supabase.co/storage/v1/s3

# Chave de acesso S3
S3_ACCESS_KEY=your_s3_access_key_here

# Chave secreta S3
S3_SECRET_KEY=your_s3_secret_key_here

# Região do S3
S3_REGION=sa-east-1

# Bucket do S3
S3_BUCKET_NAME=your_bucket_name
